<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE score-partwise PUBLIC "-//Recordare//DTD MusicXML 3.1 Partwise//EN" "http://www.musicxml.org/dtds/partwise.dtd">
<score-partwise version="3.1">
  <work>
    <work-title>30 Etudes for the Double Bass, No. 1 (mm. 1-3, Contrabass part)</work-title>
  </work>
  <identification>
    <creator type="composer">Franz Simandl</creator>
    <encoding>
      <encoding-date>2026-06-30</encoding-date>
      <software>Hand-transcribed by Claude from the IMSLP scan (Part I, p.1) for Music Copilot testing</software>
    </encoding>
  </identification>
  <!--
    NOT a verified transcription. Hand-read from a screenshot/scan of the
    IMSLP public-domain edition (Simandl, 30 Etudes for the Double Bass,
    Pt. I, p.1, Etude No. 1, Contrabass staff only - the piano accompaniment
    is omitted). Rhythm/structure (4/4, half notes descending then a
    dotted-half + quarter cadential figure, Maestoso quarter=100, forte) is
    read with reasonable confidence; exact pitches are a best-effort visual
    read, not pixel-verified OMR - automated OMR was attempted first
    (oemer: blocked, needs model weights from a non-allowlisted host;
    a "free OMR" web tool: returned a fake hardcoded stub, not a real
    conversion) before falling back to manual transcription. Treat this
    fixture as a real-world MusicXML structure/engraving test for the
    ingester, not as a musically authoritative source - cross-check
    against the original IMSLP scan if exact pitch accuracy matters.

    <transpose> below declares double bass's standard notation convention
    (written a full octave above sounding pitch) - the pitches typed into
    each <note> are WRITTEN staff positions, i.e. exactly what's read off
    the page. MusicXMLIngester calls toSoundingPitch() before extracting
    notes, so the ingested Score's MIDI values end up an octave lower than
    what's typed here - matching the actual sounding pitch a real
    recording's pitch tracker would detect. This was found via a real
    double bass player's account of their own recording (open A string
    written as A3 in this etude's book, but sounds A2) - see git history/
    STATUS.md for the fuller writeup.
  -->
  <part-list>
    <score-part id="P1">
      <part-name>Double Bass</part-name>
      <part-abbreviation>D.B.</part-abbreviation>
    </score-part>
  </part-list>
  <part id="P1">
    <measure number="1">
      <attributes>
